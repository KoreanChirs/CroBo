FROM nvidia/cuda:11.6.2-cudnn8-devel-ubuntu20.04 

ENV LANG=C.UTF-8 LC_ALL=C.UTF-8
ENV PATH /opt/conda/bin:$PATH
ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential git curl ca-certificates wget unzip \
    libgl1-mesa-dev libgl1-mesa-glx libglew-dev libosmesa6-dev \
    libglfw3 libglfw3-dev patchelf libvulkan1 libglib2.0-0 \
    mesa-utils-extra libglvnd-dev \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /usr/share/glvnd/egl_vendor.d/ && \
    printf "{\n    \"file_format_version\" : \"1.0.0\",\n    \"ICD\" : {\n        \"library_path\" : \"libEGL_nvidia.so.0\"\n    }\n}\n" > /usr/share/glvnd/egl_vendor.d/10_nvidia.json

ENV MUJOCO_GL=egl
ENV PYOPENGL_PLATFORM=egl
ENV EGL_PLATFORM=device
ENV LD_PRELOAD=/usr/lib/x86_64-linux-gnu/libEGL.so.1:/usr/lib/x86_64-linux-gnu/libGLdispatch.so.0

RUN wget --quiet https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O ~/miniconda.sh && \
    /bin/bash ~/miniconda.sh -b -p /opt/conda && \
    rm ~/miniconda.sh && \
    ln -s /opt/conda/etc/profile.d/conda.sh /etc/profile.d/conda.sh

RUN mkdir -p /root/.mujoco && \
    wget https://www.roboti.us/download/mujoco200_linux.zip -P /root/.mujoco && \
    unzip /root/.mujoco/mujoco200_linux.zip -d /root/.mujoco && \
    mv /root/.mujoco/mujoco200_linux /root/.mujoco/mujoco200 && \
    wget https://www.roboti.us/file/mjkey.txt -P /root/.mujoco
ENV LD_LIBRARY_PATH /root/.mujoco/mujoco200/bin:${LD_LIBRARY_PATH}

WORKDIR /workspace/eai-vc

COPY environment.yml .
RUN conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main && \
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r && \
    conda env create -f environment.yml && \
    conda clean -afy

ENV CONDA_DEFAULT_ENV eai-vc
ENV PATH /opt/conda/envs/eai-vc/bin:$PATH

COPY . .
RUN pip install --no-cache-dir msgpack==1.0.5 webdataset pin==2.7.0

RUN pip install -e ./third_party/mujoco-py && \
    pip install -e ./third_party/mj_envs && \
    pip install -e ./third_party/mjrl && \
    pip install -e ./third_party/dmc2gym && \
    pip install -e ./third_party/metaworld && \
    cd third_party/habitat-lab && python setup.py develop --all && cd ../.. && \
    pip install -e ./third_party/trifinger_simulation && \
    pip install -e ./vc_models && \
    pip install -e ./cortexbench/mujoco_vc && \
    pip install -e ./cortexbench/habitat_vc && \
    pip install -e ./cortexbench/trifinger_vc && \
    pip install "cython<3" && \
    pip install "mujoco==2.3.5"

RUN pip install --no-cache-dir joblib hydra-core hydra-joblib-launcher

ENV LD_PRELOAD=/usr/lib/x86_64-linux-gnu/libEGL.so.1:/usr/lib/x86_64-linux-gnu/libGL.so.1:/usr/lib/x86_64-linux-gnu/libGLdispatch.so.0
ENV GLEW_SCALABLE=1

CMD ["/bin/bash"]